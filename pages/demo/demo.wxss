.container { padding: 40rpx; padding-bottom: 120rpx; }
.status { font-size: 32rpx; color: #333; margin-bottom: 24rpx; padding: 16rpx 24rpx; background: #f5f5f5; border-radius: 12rpx; }

/* 实时心率 */
.data-row.realtime { padding: 20rpx 24rpx; background: #fff3f3; border-radius: 12rpx; margin-bottom: 20rpx; }
.data-row.realtime .hint { color: #e74c3c; margin-left: 12rpx; font-size: 24rpx; }

/* 测量结果卡片 */
.data-card { padding: 16rpx 24rpx; margin-bottom: 16rpx; background: #fff; border-radius: 12rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.label { font-size: 24rpx; color: #999; display: block; margin-bottom: 4rpx; }
.value { font-size: 40rpx; font-weight: 600; color: #333; }
.sub { font-size: 24rpx; color: #999; margin-top: 4rpx; }

/* 操作区 */
.actions { margin-top: 30rpx; }
.section-title { font-size: 26rpx; color: #999; margin: 20rpx 0 12rpx; padding-left: 4rpx; }
.btn-row { display: flex; flex-wrap: wrap; gap: 16rpx; }
.btn-row button { flex: 0 0 auto; min-width: 140rpx; }
